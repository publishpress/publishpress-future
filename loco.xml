<?xml version="1.0" encoding="utf-8"?>
<bundle name="PublishPress Future">
  <domain name="post-expirator">
    <project name="PublishPress Future">
      <source>
        <directory>src</directory>
        <directory>legacy</directory>
        <directory>assets/jsx</directory>
        <file>post-expirator.php</file>
        <file>services.php</file>
      </source>
      <target>
        <directory>languages</directory>
      </target>
      <template>
        <file>languages/post-expirator.pot</file>
      </template>
    </project>
  </domain>
  <domain name="publishpress-wordpress-reviews">
    <project name="PublishPress WordPress Reviews">
      <source>
        <directory>lib/vendor/publishpress/wordpress-reviews</directory>
      </source>
      <target>
        <directory>lib/vendor/publishpress/wordpress-reviews/languages</directory>
      </target>
      <template>
        <file>lib/vendor/publishpress/wordpress-reviews/languages/publishpress-wordpress-reviews.pot</file>
      </template>
    </project>
  </domain>
  <domain name="publishpress-wordpress-version-notices">
    <project name="PublishPress WordPress Version Notices">
      <source>
        <directory>lib/vendor/publishpress/wordpress-version-notices</directory>
      </source>
      <target>
        <directory>lib/vendor/publishpress/wordpress-version-notices/languages</directory>
      </target>
      <template>
        <file>lib/vendor/publishpress/wordpress-version-notices/languages/publishpress-wordpress-version-notices.pot</file>
      </template>
    </project>
  </domain>
  <domain name="publishpress-instance-protection">
    <project name="PublishPress Instance Protection">
      <source>
        <directory>lib/vendor/publishpress/instance-protection/core</directory>
      </source>
      <target>
        <directory>lib/vendor/publishpress/instance-protection/languages</directory>
      </target>
      <template>
        <file>lib/vendor/publishpress/instance-protection/languages/publishpress-instance-protection.pot</file>
      </template>
    </project>
  </domain>
</bundle>
