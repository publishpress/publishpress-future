{
    "name": "publishpress/publishpress-future",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "description": "",
    "authors": [
        {
            "name": "PublishPress",
            "email": "help@publishpress.com",
            "homepage": "https://publishpress.com",
            "role": "Developer"
        },
        {
            "name": "Aaron Axelsen",
            "homepage": "http://postexpirator.tuxdocs.net/"
        }
    ],
    "config": {
        "preferred-install": {
            "*": "dist"
        },
        "allow-plugins": {
            "automattic/jetpack-autoloader": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true
        },
        "process-timeout": 0
    },
    "prefer-stable": true,
    "minimum-stability": "stable",
    "require": {
        "php": ">=7.4",
        "ext-json": "*"
    },
    "require-dev": {
        "automattic/vipwpcs": "^3",
        "behat/behat": "^3.14",
        "codeception/module-asserts": "^3",
        "codeception/module-cli": "^2",
        "codeception/module-db": "^3",
        "codeception/module-filesystem": "^3",
        "codeception/module-phpbrowser": "^3",
        "codeception/module-rest": "^3",
        "codeception/module-sequence": "^3",
        "codeception/module-webdriver": "^3",
        "codeception/util-universalframework": "^1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1",
        "friendsofphp/php-cs-fixer": "^3.49",
        "knplabs/github-api": "^3.16",
        "lucatume/wp-browser": "^4",
        "nyholm/psr7": "^1.8",
        "overtrue/phplint": "^9.1",
        "phpcompatibility/php-compatibility": "^9.3",
        "phpmd/phpmd": "^2.15",
        "phpmetrics/phpmetrics": "^2.9",
        "phpstan/extension-installer": "^1.3",
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^10",
        "publishpress/publishpress-phpcs-standards": "dev-main",
        "spatie/ray": "^1.41",
        "squizlabs/php_codesniffer": "^3.8",
        "symfony/http-client": "^7.1",
        "symfony/process": "^6.4",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "wp-cli/i18n-command": "^2.6",
        "wp-cli/wp-cli-bundle": "^2.10",
        "wp-coding-standards/wpcs": "^3"
    },
    "scripts": {
        "term": "dev-workspace/run",
        "build:all": [
            "@build:js",
            "@build:lang",
            "@build"
        ],
        "build": "@build:zip",
        "build:zip": "dev-workspace/run build zip",
        "build:dir": "dev-workspace/run build dir",
        "build:clean": "dev-workspace/run build clean",
        "build:js-prod": "dev-workspace/run cross-env NODE_ENV=production npx webpack --progress",
        "build:js-dev": "dev-workspace/run cross-env NODE_ENV=development npx webpack --progress",
        "build:js": [
            "@build:js-prod",
            "@build:js-dev"
        ],
        "profile:js": "dev-workspace/run cross-env NODE_ENV=production npx webpack --profile",
        "watch:js": "dev-workspace/run cross-env NODE_ENV=development npx webpack --watch --progress",
        "get:version": "dev-workspace/run /scripts/build version",
        "build:lang": [
            "@build:lang-pot",
            "@build:lang-mo",
            "@build:lang-json",
            "@build:lang-php"
        ],
        "build:lang-pot": "dev-workspace/run wp i18n make-pot . ./languages/post-expirator.pot --domain=post-expirator --exclude=dev-workspace,.wordpress-org,.github,dist,tests,lib,tmp,doc,*.js,*.js.map --allow-root",
        "build:lang-mo": "dev-workspace/run wp i18n make-mo ./languages ./languages --allow-root",
        "build:lang-json": "dev-workspace/run bash ./dev-workspace/scripts/lang-make-json.sh",
        "build:lang-php": "dev-workspace/run wp i18n make-php ./languages --allow-root",
        "check": [
            "@check:php",
            "@check:lint",
            "@check:cs",
            "@check:longpath"
        ],
        "check:php": [
            "@check:php-5.6",
            "@check:php-7.2",
            "@check:php-7.4",
            "@check:php-8.0",
            "@check:php-8.1",
            "@check:php-8.2",
            "@check:php-8.3",
            "@check:php-8.4",
            "@check:php-8.5"
        ],
        "check:php-5.6": "dev-workspace/run phpcs --standard=.phpcs-php-compatibility.xml --runtime-set testVersion 5.6 ./post-expirator.php",
        "check:php-7.4": "dev-workspace/run phpcs --standard=.phpcs-php-compatibility.xml --runtime-set testVersion 7.4",
        "check:php-8.0": "dev-workspace/run phpcs --standard=.phpcs-php-compatibility.xml --runtime-set testVersion 8.0",
        "check:php-8.1": "dev-workspace/run phpcs --standard=.phpcs-php-compatibility.xml --runtime-set testVersion 8.1",
        "check:php-8.2": "dev-workspace/run phpcs --standard=.phpcs-php-compatibility.xml --runtime-set testVersion 8.2",
        "check:php-8.3": "dev-workspace/run phpcs --standard=.phpcs-php-compatibility.xml --runtime-set testVersion 8.3",
        "check:php-8.4": "dev-workspace/run phpcs --standard=.phpcs-php-compatibility.xml --runtime-set testVersion 8.4",
        "check:php-8.5": "dev-workspace/run phpcs --standard=.phpcs-php-compatibility.xml --runtime-set testVersion 8.5",
        "check:lint": "dev-workspace/run phplint --no-cache",
        "check:cs": "dev-workspace/run phpcs",
        "check:stan": "dev-workspace/run phpstan",
        "check:longpath": "dev-workspace/run bash -c \"if [ ! -d 'dist/post-expirator' ]; then composer build:dir; fi && longpath dist/post-expirator/\"",
        "check:pot-diff": "dev-workspace/run php dev-workspace/scripts/php/bin/pptk pot:diff https://raw.githubusercontent.com/publishpress/PublishPress-Future/refs/heads/main/languages/post-expirator.pot ./languages/post-expirator.pot",
        "check:pot-diff-md": "dev-workspace/run php dev-workspace/scripts/php/bin/pptk pot:diff https://raw.githubusercontent.com/publishpress/PublishPress-Future/refs/heads/main/languages/post-expirator.pot ./languages/post-expirator.pot -m",
        "fix:php": [
            "dev-workspace/run php-cs-fixer fix .",
            "dev-workspace/run phpcbf --standard=.phpcs.xml"
        ],
        "up": [
            "@test:up",
            "@wp:up",
            "@env:info"
        ],
        "down": [
            "@test:down",
            "@wp:down"
        ],
        "stop": [
            "@wp:stop",
            "@test:stop"
        ],
        "env:info": [
            "@wp:info",
            "@test:info"
        ],
        "refresh": [
            "@wp:refresh",
            "@test:refresh"
        ],
        "clean": [
            "@wp:clear",
            "@test:clean"
        ],
        "logs": [
            "@wp:logs",
            "@test:logs"
        ],
        "wp:logs": "bash -c 'cd dev-workspace && set -a && source ../.env && set +a && docker compose -f docker/compose.yaml --profile dev logs --tail=100'",
        "test:logs": "bash -c 'cd dev-workspace && set -a && source ../.env && set +a && docker compose -f docker/compose.yaml --profile test logs --tail=100'",
        "wpcli:tests": "bash dev-workspace/scripts/tests-wp-cli.sh wp_test_cli $@",
        "wpcli:dev": "bash dev-workspace/scripts/tests-wp-cli.sh wp_dev_cli $@",
        "wp:up": [
            "bash dev-workspace/scripts/env.sh up dev",
            "@wp:info"
        ],
        "wp:stop": "bash dev-workspace/scripts/env.sh stop dev",
        "wp:down": "bash dev-workspace/scripts/env.sh down dev",
        "wp:restart": "bash dev-workspace/scripts/env.sh restart dev",
        "wp:clear": [
            "bash dev-workspace/scripts/env.sh cleanup dev",
            "@wp:clear-cache"
        ],
        "wp:clear-logs": "rm -f dev-workspace/.cache/logs/db_dev/",
        "wp:clear-cache": "rm -rf dev-workspace/.cache/wp_dev && rm -rf dev-workspace/.cache/db_dev",
        "wp:refresh": "bash dev-workspace/scripts/env.sh refresh dev",
        "wp:info": "bash dev-workspace/scripts/env.sh info dev",
        "lib:install": "./dev-workspace/run composer install $@",
        "lib:update": "./dev-workspace/run composer update $@",
        "lib:update:lib": "./dev-workspace/run composer update --working-dir=./lib $@",
        "sync:local": "bash dev-workspace/scripts/local-sync.sh --watch",
        "sync:local:once": "bash dev-workspace/scripts/local-sync.sh",
        "sync:local:stop": "pkill -f local-sync.sh || true",
        "sync:remote": "bash dev-workspace/scripts/sync-plugin-remote.sh --watch",
        "sync:remote:once": "bash dev-workspace/scripts/sync-plugin-remote.sh --once",
        "sync:remote:stop": "pkill -f sync-plugin-remote.sh || true",
        "test": "vendor/bin/codecept run $@",
        "test:up": [
            "bash dev-workspace/scripts/env.sh up test",
            "@test:info"
        ],
        "test:driver": "source ./.env && $CHROMEDRIVER_BINARY --port=$CHROMEDRIVER_PORT",
        "test:down": "bash dev-workspace/scripts/env.sh down test",
        "test:restart": "bash dev-workspace/scripts/env.sh restart test",
        "test:stop": "bash dev-workspace/scripts/env.sh stop test",
        "test:clean": [
            "bash dev-workspace/scripts/env.sh cleanup test",
            "@test:clean-cache",
            "composer codecept clean"
        ],
        "test:clean-logs": "rm -f dev-workspace/.cache/logs/db_test/",
        "test:clean-cache": "rm -rf dev-workspace/.cache/wp_test && rm -rf dev-workspace/.cache/db_test",
        "test:db-export": "bash dev-workspace/scripts/tests-db-export.sh $@",
        "test:db-import": "bash dev-workspace/scripts/tests-db-import.sh $@",
        "test:db-logs": "bash dev-workspace/scripts/tests-db-logs.sh $@",
        "test:info": "bash dev-workspace/scripts/env.sh info test",
        "test:refresh": "bash dev-workspace/scripts/env.sh refresh test",
        "test:snippets": "composer codecept gherkin:snippets $@",
        "test:steps": "composer codecept gherkin:steps $@",
        "test:all": [
            "vendor/bin/codecept run Unit",
            "vendor/bin/codecept run Integration"
        ],
        "test:coverage": "vendor/bin/codecept run --coverage --coverage-html $@",
        "test:unit": "vendor/bin/codecept run Unit $@",
        "test:integration": "vendor/bin/codecept run Integration $@",
        "test:acceptance": "vendor/bin/codecept run Acceptance $@",
        "test:end-to-end": "vendor/bin/codecept run EndToEnd $@",
        "test:debug": "php -d xdebug.mode=debug -d xdebug.start_with_request=yes vendor/bin/codecept run $@",
        "codecept": "./vendor/bin/codecept $@",
        "docker:cleanup": "docker system prune -f",
        "info:versions": "bash ./dev-workspace/scripts/dependency-versions.sh",
        "set:version": "php ./dev-workspace/scripts/plugin-bump-version.php \"$@\"",
        "pre-release": "bash ./dev-workspace/scripts/pre-release.sh \"$@\"",
        "pr-link": "bash ./dev-workspace/scripts/pr-link.sh",
        "pre-commit-check": [
            "@check",
            "@test:unit",
            "@test:integration"
        ],
        "after-pr-merge": "bash dev-workspace/scripts/after-pr-merge.sh",
        "config:phpcs": "phpcs --config-set installed_paths \"../../phpcsstandards/phpcsutils,../../phpcsstandards/phpcsextra,../../automattic/vipwpcs,../../phpcompatibility/php-compatibility,../../sirbrillig/phpcs-variable-analysis,../../publishpress/publishpress-phpcs-standards/standards,../../wp-coding-standards/wpcs\"",
        "post-install-cmd": [
            "@config:phpcs"
        ],
        "post-update-cmd": [
            "@config:phpcs"
        ],
        "pre-autoload-dump": "@composer dumpautoload --working-dir=./lib",
        "pre-update-cmd": "@composer update --working-dir=./lib",
        "pre-install-cmd": "@composer install --working-dir=./lib",
        "metrics": "phpmetrics --report-html=metrics --exclude=vendor,lib/vendor,tests,dist,dev-workspace,.claude,.cursor,.github,.wordpress-org,.git,.zed,docs,languages ."
    },
    "scripts-descriptions": {
        "term": "Runs a command inside the dev-workspace container",
        "build": "Builds the plugin zip package",
        "build:all": "Builds JavaScript, language files, and the plugin",
        "build:zip": "Builds the plugin zip package",
        "build:dir": "Builds the plugin in a directory",
        "build:clean": "Cleans up the build directory",
        "build:js-prod": "Builds the JavaScript files in production mode",
        "build:js-dev": "Builds the JavaScript files in development mode",
        "build:js": "Builds the JavaScript files in production and development mode",
        "profile:js": "Generates a profile of the JavaScript build",
        "watch:js": "Watches the JavaScript files for changes",
        "get:version": "Gets the version of the plugin",
        "build:lang-pot": "Generates the POT file for translations of PHP and JSX files",
        "build:lang-mo": "Generates the MO files for translation files",
        "build:lang-json": "Generates the JSON translation files for JavaScript",
        "build:lang-php": "Generates the PHP language files for performant translations (WP 6.5+)",
        "build:lang": "Generates the language files for translations",
        "check": "Runs all the checks",
        "check:php": "Checks the PHP compatibility for all versions",
        "check:php-5.6": "Checks the PHP compatibility for PHP 5.6 in the main file only",
        "check:php-7.4": "Checks the PHP compatibility for PHP 7.4",
        "check:php-8.0": "Checks the PHP compatibility for PHP 8.0",
        "check:php-8.1": "Checks the PHP compatibility for PHP 8.1",
        "check:php-8.2": "Checks the PHP compatibility for PHP 8.2",
        "check:php-8.3": "Checks the PHP compatibility for PHP 8.3",
        "check:php-8.4": "Checks the PHP compatibility for PHP 8.4",
        "check:php-8.5": "Checks the PHP compatibility for PHP 8.5",
        "check:lint": "Checks the PHP files for syntax errors",
        "check:cs": "Checks the PHP files for coding standards",
        "check:stan": "Runs PHPStan static analysis",
        "check:longpath": "Checks for long file paths in the build",
        "check:pot-diff": "Compares POT file with main branch",
        "check:pot-diff-md": "Compares POT file with main branch (Markdown output)",
        "fix:php": "Fixes PHP coding standards (CS-Fixer and phpcbf)",
        "sync:local": "Syncs plugin files to the local dev site",
        "sync:local:watch": "Watches and syncs plugin files to the local dev site",
        "test:driver": "Starts the ChromeDriver server",
        "test:clean": "Cleans up the test environment, cache, and Codeception",
        "test:clean-cache": "Removes the test cache files",
        "test:clean-logs": "Removes the test database logs",
        "test:db-export": "Exports the WordPress database to a SQL file",
        "test:db-import": "Imports a SQL file into the WordPress test database",
        "test:db-logs": "Shows database logs for the test environment",
        "test:down": "Stops and removes the test containers",
        "test:info": "Shows test environment information",
        "test:refresh": "Refreshes the test environment",
        "test:restart": "Restarts the test environment",
        "test:stop": "Stops the test environment",
        "test:up": "Starts the test environment",
        "wp:up": "Starts the WordPress dev environment",
        "wp:stop": "Stops the WordPress dev environment",
        "wp:down": "Stops and removes the WordPress dev containers",
        "wp:restart": "Restarts the WordPress dev environment",
        "wp:clear": "Cleans up the WordPress dev environment and cache",
        "wp:clear-logs": "Removes the WordPress dev database logs",
        "wp:clear-cache": "Removes the WordPress dev cache files",
        "wp:refresh": "Refreshes the WordPress dev environment",
        "wp:info": "Shows WordPress dev environment information",
        "lib:install": "Runs composer install in the dev-workspace container",
        "lib:update": "Runs composer update in the dev-workspace container",
        "lib:update:lib": "Runs composer update for the lib directory in the dev-workspace container",
        "wpcli:tests": "Runs WP-CLI in the test environment",
        "wpcli:dev": "Runs WP-CLI in the WordPress dev environment",
        "test:snippets": "Shows Gherkin snippets not yet implemented",
        "test:steps": "Shows all Gherkin steps for the suite",
        "test": "Runs tests with optional arguments or specific suites",
        "test:debug": "Runs tests in debug mode with Xdebug",
        "codecept": "Runs Codeception commands",
        "docker:cleanup": "Removes unused Docker resources",
        "config:phpcs": "Configures the PHP CodeSniffer installed paths",
        "info:versions": "Shows versions of main tools",
        "set:version": "Sets the plugin version",
        "pre-release": "Creates a release branch and pull request",
        "pr-link": "Gets the PR URL for the release branch",
        "up": "Starts both test and WordPress dev environments",
        "down": "Stops both test and WordPress dev environments",
        "stop": "Stops both environments without removing containers",
        "env:info": "Shows info for both WordPress dev and test environments",
        "refresh": "Refreshes both WordPress dev and test environments",
        "clean": "Cleans up both WordPress dev and test environments",
        "logs": "Shows logs for both WordPress dev and test environments",
        "wp:logs": "Shows Docker logs for the WordPress dev environment",
        "test:logs": "Shows Docker logs for the test environment",
        "test:coverage": "Generates test coverage report",
        "test:unit": "Runs unit tests",
        "test:integration": "Runs integration tests",
        "test:acceptance": "Runs acceptance tests",
        "test:end-to-end": "Runs end-to-end tests",
        "sync:local:stop": "Stops the local sync process",
        "sync:remote": "Watches and syncs plugin files to remote dev site",
        "sync:remote:once": "Syncs plugin files once to remote dev site",
        "sync:remote:stop": "Stops the remote sync process",
        "pre-commit-check": "Runs checks, unit and integration tests",
        "after-pr-merge": "Runs post-merge tasks",
        "metrics": "Generates the PHP metrics report"
    },
    "extra": {
        "plugin-slug": "post-expirator",
        "plugin-name": "publishpress-future",
        "plugin-folder": "post-expirator",
        "version-constant": "PUBLISHPRESS_FUTURE_VERSION"
    }
}
