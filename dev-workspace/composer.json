    "pack:clean": "Clean build output from the packaging step",
    "build:js-prod": "Build JavaScript assets for production",
    "build:js-dev": "Build JavaScript assets for development",
    "build:js": "Build JavaScript for production and development",
    "profile:js": "Profile the JavaScript webpack build",
    "watch:js": "Watch JavaScript sources and rebuild on change",
    "get:version": "Print the plugin version from the build metadata",
    "check:all": "Run PHP compatibility, phplint, PHPCS, and long-path checks",
